{"type":"header","kind":"domain","name":"skynet_timer","mk":2,"goal":"static AGI/RSI countdown site (skynet-timer.com) tuning + i18n maintenance + drift-resistance","required_conditions":[{"id":"st.cond.1","desc":"timer.js AGI/RSI Date.UTC anchor stable (2029-01-01 / 2035-01-01)","verifier":"grep -n 'Date.UTC(2029' timer.js && grep -n 'Date.UTC(2035' timer.js","status":"met","evidence":["timer.js:2-3"],"blocker_reason":""},{"id":"st.cond.2","desc":"i18n 5-lang full coverage (en/ko/ja/zh/ru) — npt + proof + verify keys non-empty","verifier":"node -e \"const f=require('fs').readFileSync('i18n.js','utf8');['en','ko','ja','zh','ru'].forEach(l=>{const m=f.match(new RegExp(l+':\\\\s*\\\\{','g'));console.log(l,m?'ok':'MISS')})\"","status":"met","evidence":["i18n.js:5(en) i18n.js:355(ko) i18n.js:675(ja) i18n.js:995(zh) i18n.js:1315(ru)"],"blocker_reason":""},{"id":"st.cond.3","desc":"timeline now-marker year auto-updates (no hardcoded year drift)","verifier":"grep -n 'tl-now-year' timer.js","status":"unmet","evidence":["index.html:100 hardcodes 2026 with no JS sync"],"blocker_reason":"timer.js layoutTimeline computes positions but does not write tl-now-year textContent"},{"id":"st.cond.4","desc":"acceleration table 2026 row remains current (Epoch AI / Our World in Data)","verifier":"grep -n 'data-col=\"Year\">2026<' index.html","status":"met","evidence":["index.html:295"],"blocker_reason":""},{"id":"st.cond.5","desc":"share.text + og-image consistent with current Φ_c framing (Φ=0 vs Φ=1.89)","verifier":"grep -n 'Φ=0 vs Φ=1.89' index.html i18n.js og-image.svg","status":"met","evidence":["index.html:7,11,18 og-image.svg(visual) i18n.js:33(en share)"],"blocker_reason":""},{"id":"st.cond.6","desc":"GitHub Pages deploy hygiene (.nojekyll + CNAME) intact","verifier":"test -f .nojekyll && test -f CNAME && cat CNAME","status":"met","evidence":[".nojekyll(0B) CNAME=skynet-timer.com"],"blocker_reason":""}],"blockers":[],"status":"active","since":"2026-05-02","origin_repo":"skynet-timer","perspective":"producer","provider_dependency":"none","downstream_consumers":["anima:docs/singularity-heaven-or-skynet.md(referenced from README)"]}
